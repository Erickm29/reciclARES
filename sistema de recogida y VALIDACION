<!DOCTYPE html>
<html lang="es" class="light">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<title>Verificar Entrega - Fundares</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script>
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      colors: {
        "primary": "#00450d",
        "on-primary": "#ffffff",
        "primary-container": "#1b5e20",
        "on-primary-container": "#90d689",
        "primary-fixed": "#acf4a4",
        "primary-fixed-dim": "#91d78a",
        "secondary": "#3c6842",
        "on-secondary": "#ffffff",
        "secondary-container": "#bdefbe",
        "on-secondary-container": "#426e47",
        "tertiary": "#00450d",
        "tertiary-container": "#055f18",
        "on-tertiary-container": "#86d881",
        "surface": "#f9f9f9",
        "surface-bright": "#f9f9f9",
        "surface-container-lowest": "#ffffff",
        "surface-container-low": "#f3f3f3",
        "surface-container": "#eeeeee",
        "surface-container-high": "#e8e8e8",
        "surface-container-highest": "#e2e2e2",
        "surface-dim": "#dadada",
        "on-surface": "#1a1c1c",
        "on-surface-variant": "#41493e",
        "background": "#f9f9f9",
        "on-background": "#1a1c1c",
        "outline": "#717a6d",
        "outline-variant": "#c0c9bb",
        "inverse-surface": "#2f3131",
        "inverse-on-surface": "#f1f1f1",
        "inverse-primary": "#91d78a",
        "error": "#ba1a1a",
        "on-error": "#ffffff",
        "error-container": "#ffdad6",
        "on-error-container": "#93000a",
        "surface-tint": "#2a6b2c",
      },
      borderRadius: {
        "DEFAULT": "0.125rem",
        "lg": "0.25rem",
        "xl": "0.5rem",
        "full": "0.75rem",
      },
      spacing: {
        "sm": "8px", "md": "16px", "lg": "24px", "xl": "32px",
        "xs": "4px", "unit": "4px", "gutter": "16px",
        "margin-mobile": "16px", "tap-target-min": "48px",
      },
      fontSize: {
        "display-lg": ["48px", {lineHeight:"56px",letterSpacing:"-0.02em",fontWeight:"700"}],
        "headline-lg": ["32px", {lineHeight:"40px",letterSpacing:"-0.01em",fontWeight:"600"}],
        "headline-lg-mobile": ["24px", {lineHeight:"32px",fontWeight:"600"}],
        "title-md": ["20px", {lineHeight:"28px",fontWeight:"600"}],
        "body-lg": ["18px", {lineHeight:"28px",fontWeight:"400"}],
        "body-md": ["16px", {lineHeight:"24px",fontWeight:"400"}],
        "label-md": ["14px", {lineHeight:"20px",letterSpacing:"0.01em",fontWeight:"500"}],
        "label-sm": ["12px", {lineHeight:"16px",letterSpacing:"0.05em",fontWeight:"600"}],
      }
    }
  }
}
</script>
<style>
  * { font-family: 'Inter', sans-serif; }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  body { min-height: max(884px, 100dvh); background: #f9f9f9; }

  /* Entrada suave de la card de alerta */
  @keyframes slide-up {
    from { transform: translateY(24px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes ping-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .alert-card { animation: slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .ping-dot { animation: ping-dot 1.8s ease-in-out infinite; }
  .fade-in { animation: fade-in 0.3s ease both; }

  /* Overlay de resultado */
  #result-overlay { transition: opacity 0.3s ease; }
  #result-overlay.hidden { display: none !important; }

  /* Número grande de kg animado */
  @keyframes count-up {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }
  .kg-display { animation: count-up 0.5s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both; }

  /* Botón rechazo expandible */
  .reject-panel { max-height: 0; overflow: hidden; transition: max-height 0.35s ease, opacity 0.3s ease; opacity: 0; }
  .reject-panel.open { max-height: 200px; opacity: 1; }
</style>
</head>
<body class="text-on-background overflow-x-hidden">

<!-- Top AppBar -->
<header class="fixed top-0 w-full bg-surface border-b border-outline-variant flex items-center justify-between px-margin-mobile h-tap-target-min z-50">
  <div class="flex items-center gap-md">
    <span class="material-symbols-outlined text-primary cursor-pointer active:scale-90 transition-transform" onclick="history.back()">arrow_back</span>
    <div>
      <h1 class="font-headline-lg-mobile text-headline-lg-mobile text-primary leading-tight">Verificar Entrega</h1>
    </div>
  </div>
  <div class="flex items-center gap-md">
    <!-- Badge de alerta activa -->
    <div class="relative">
      <span class="material-symbols-outlined text-primary">notifications</span>
      <span class="absolute -top-1 -right-1 w-3 h-3 bg-error rounded-full border-2 border-surface ping-dot"></span>
    </div>
    <div class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center">
      <span class="font-label-sm text-label-sm text-on-secondary-container">MA</span>
    </div>
  </div>
</header>

<!-- Main -->
<main class="pt-[64px] pb-[88px] px-margin-mobile max-w-lg mx-auto space-y-lg">

  <!-- Banner de estado: Por Verificar -->
  <section class="mt-lg alert-card">
    <div class="bg-[#fff8e1] border border-[#f9a825] rounded-xl p-md flex items-start gap-md">
      <div class="mt-xs">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#f9a825] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-[#f9a825]"></span>
        </span>
      </div>
      <div class="flex-1">
        <p class="font-label-sm text-label-sm text-[#e65100] uppercase tracking-wider mb-xs">Acción requerida</p>
        <p class="font-label-md text-label-md text-on-surface">El recogedor ha registrado una entrega. Confirma los datos para cerrar la transacción.</p>
      </div>
    </div>
  </section>

  <!-- Card principal: Datos del recogedor -->
  <section class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden alert-card" style="animation-delay: 0.05s">

    <!-- Header de la card -->
    <div class="bg-primary-container px-lg py-md flex items-center justify-between">
      <div class="flex items-center gap-md">
        <div class="w-10 h-10 rounded-full bg-surface-container-lowest flex items-center justify-center">
          <span class="font-label-md text-label-md text-primary-container font-bold">JR</span>
        </div>
        <div>
          <p class="font-label-sm text-label-sm text-on-primary-container opacity-80 uppercase tracking-wider">Recogedor</p>
          <p class="font-title-md text-title-md text-on-primary-container">Juan Ríos</p>
        </div>
      </div>
      <div class="text-right">
        <span class="inline-flex items-center gap-xs px-sm py-xs bg-[#f9a825]/20 border border-[#f9a825]/40 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-[#f9a825] inline-block"></span>
          <span class="font-label-sm text-label-sm text-[#e65100]">Por Verificar</span>
        </span>
      </div>
    </div>

    <!-- Metadata de la orden -->
    <div class="px-lg py-md border-b border-outline-variant grid grid-cols-2 gap-md">
      <div>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs">Orden</p>
        <p class="font-label-md text-label-md text-on-surface font-bold">#7b2a9f4e</p>
      </div>
      <div>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs">Empresa</p>
        <p class="font-label-md text-label-md text-on-surface font-bold">TechCorp</p>
      </div>
      <div>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs">Registrado</p>
        <p class="font-label-md text-label-md text-on-surface">Hoy, 10:47 AM</p>
      </div>
      <div>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs">Ubicación</p>
        <p class="font-label-md text-label-md text-on-surface">Av. Industrial 123</p>
      </div>
    </div>

    <!-- Datos reportados: Material + Peso -->
    <div class="px-lg py-lg">
      <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-md">Datos reportados por el recogedor</p>

      <div class="grid grid-cols-2 gap-md">
        <!-- Material -->
        <div class="bg-secondary-container rounded-xl p-md flex flex-col gap-xs">
          <span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">layers</span>
          <p class="font-label-sm text-label-sm text-on-secondary-container opacity-80 uppercase tracking-wider">Material</p>
          <p class="font-title-md text-title-md text-on-surface">PET</p>
          <p class="font-label-sm text-label-sm text-on-surface-variant">Plástico tipo 1</p>
        </div>

        <!-- Peso -->
        <div class="bg-primary-container rounded-xl p-md flex flex-col gap-xs">
          <span class="material-symbols-outlined text-on-primary-container text-[20px]" style="font-variation-settings: 'FILL' 1;">scale</span>
          <p class="font-label-sm text-label-sm text-on-primary-container opacity-80 uppercase tracking-wider">Peso</p>
          <p class="font-display-lg text-on-primary-container kg-display" style="font-size:36px; font-weight:700; line-height:1">45</p>
          <p class="font-label-sm text-label-sm text-on-primary-container opacity-80">kilogramos</p>
        </div>
      </div>

      <!-- Foto del material -->
      <div class="mt-md rounded-xl overflow-hidden border border-outline-variant relative group cursor-pointer">
        <div class="aspect-video bg-surface-container flex items-center justify-center relative">
          <!-- Placeholder foto -->
          <div class="absolute inset-0 bg-gradient-to-br from-surface-container to-surface-container-high flex flex-col items-center justify-center gap-sm">
            <span class="material-symbols-outlined text-on-surface-variant text-[40px]">image</span>
            <p class="font-label-md text-label-md text-on-surface-variant">Foto adjunta por el recogedor</p>
          </div>
          <!-- Badge foto -->
          <div class="absolute top-sm right-sm bg-surface-container-lowest/90 backdrop-blur-sm px-sm py-xs rounded-full border border-outline-variant flex items-center gap-xs">
            <span class="material-symbols-outlined text-primary text-[14px]" style="font-variation-settings: 'FILL' 1;">photo_camera</span>
            <span class="font-label-sm text-label-sm text-primary">1 foto</span>
          </div>
        </div>
      </div>

      <!-- Notas -->
      <div class="mt-md bg-surface-container rounded-xl p-md flex items-start gap-md">
        <span class="material-symbols-outlined text-on-surface-variant text-[18px] mt-xs">notes</span>
        <div>
          <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs">Notas del recogedor</p>
          <p class="font-body-md text-body-md text-on-surface">Material pre-separado, sin contaminantes. Listo para planta de procesamiento.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección: Corrección de peso (editable) -->
  <section class="bg-surface-container-lowest border border-outline-variant rounded-xl px-lg py-md alert-card" style="animation-delay: 0.1s">
    <div class="flex items-center justify-between mb-md">
      <p class="font-label-md text-label-md text-on-surface font-bold">¿El peso es correcto?</p>
      <button onclick="toggleEdit()" id="edit-btn" class="flex items-center gap-xs text-primary active:scale-95 transition-transform">
        <span class="material-symbols-outlined text-[18px]" id="edit-icon">edit</span>
        <span class="font-label-sm text-label-sm uppercase tracking-wider" id="edit-label">Corregir</span>
      </button>
    </div>

    <div id="edit-panel" class="hidden fade-in">
      <label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider mb-xs block">Peso correcto (kg)</label>
      <div class="relative">
        <input type="number" id="corrected-weight" value="45" min="0" step="0.1"
          class="w-full h-tap-target-min px-md pr-12 border border-outline-variant rounded-lg bg-surface-container-lowest focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none font-body-md text-body-md"/>
        <span class="absolute right-md top-1/2 -translate-y-1/2 font-label-md text-on-surface-variant">kg</span>
      </div>
      <p class="font-label-sm text-label-sm text-on-surface-variant mt-xs">El despachador puede corregir el peso antes de aprobar.</p>
    </div>

    <div id="weight-display" class="flex items-center gap-md">
      <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
      </div>
      <div>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Peso confirmado</p>
        <p class="font-title-md text-title-md text-on-surface"><span id="weight-val">45</span> kg de PET</p>
      </div>
    </div>
  </section>

  <!-- Panel de rechazo (oculto inicialmente) -->
  <div id="reject-panel" class="reject-panel">
    <section class="bg-error-container border border-[#f1998e] rounded-xl px-lg py-md space-y-md">
      <p class="font-label-sm text-label-sm text-on-error-container uppercase tracking-wider">Motivo del rechazo</p>
      <div class="grid grid-cols-1 gap-sm">
        <button onclick="selectReason(this)" data-reason="Peso incorrecto" class="reason-btn flex items-center gap-md p-md border border-[#f1998e] rounded-xl bg-surface-container-lowest active:scale-95 transition-all text-left">
          <span class="material-symbols-outlined text-error text-[20px]">scale</span>
          <span class="font-label-md text-label-md text-on-surface">Peso incorrecto</span>
        </button>
        <button onclick="selectReason(this)" data-reason="Material equivocado" class="reason-btn flex items-center gap-md p-md border border-[#f1998e] rounded-xl bg-surface-container-lowest active:scale-95 transition-all text-left">
          <span class="material-symbols-outlined text-error text-[20px]">layers_clear</span>
          <span class="font-label-md text-label-md text-on-surface">Material equivocado</span>
        </button>
        <button onclick="selectReason(this)" data-reason="Material contaminado" class="reason-btn flex items-center gap-md p-md border border-[#f1998e] rounded-xl bg-surface-container-lowest active:scale-95 transition-all text-left">
          <span class="material-symbols-outlined text-error text-[20px]">warning</span>
          <span class="font-label-md text-label-md text-on-surface">Material contaminado</span>
        </button>
      </div>
      <textarea id="reject-notes" placeholder="Comentario adicional (opcional)..." rows="2"
        class="w-full px-md py-md border border-[#f1998e] rounded-lg bg-surface-container-lowest focus:ring-2 focus:ring-error focus:border-error transition-all outline-none font-body-md text-body-md resize-none"></textarea>
    </section>
  </div>

</main>

<!-- Bottom Action Bar -->
<div class="fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant px-margin-mobile py-md z-50 max-w-lg mx-auto left-1/2 -translate-x-1/2" style="left:50%;transform:translateX(-50%);max-width:512px;width:100%">
  <div class="grid grid-cols-2 gap-md" id="action-buttons">

    <!-- Rechazar -->
    <button onclick="handleReject()" id="reject-btn"
      class="h-tap-target-min border-2 border-error bg-surface-container-lowest text-error rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm active:scale-95 transition-all hover:bg-error-container">
      <span class="material-symbols-outlined text-[20px]">cancel</span>
      Rechazar
    </button>

    <!-- Aprobar -->
    <button onclick="handleApprove()" id="approve-btn"
      class="h-tap-target-min bg-primary text-on-primary rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm active:scale-[0.97] transition-all hover:opacity-90 shadow-md">
      <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
      Aprobar
    </button>

  </div>
  <!-- Confirmar rechazo (aparece cuando se expande el panel) -->
  <button id="confirm-reject-btn" onclick="confirmReject()"
    class="hidden w-full mt-md h-tap-target-min bg-error text-on-error rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm active:scale-[0.97] transition-all shadow-md fade-in">
    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">block</span>
    Confirmar Rechazo
  </button>
</div>

<!-- Overlay: Aprobado -->
<div id="result-overlay" class="fixed inset-0 z-[100] bg-primary flex flex-col items-center justify-center p-xl hidden">
  <div id="result-icon" class="scale-0 transition-transform duration-500 ease-out">
    <span class="material-symbols-outlined text-on-primary" style="font-size:96px; font-variation-settings: 'FILL' 1; 'wght' 200;">check_circle</span>
  </div>
  <h2 id="result-title" class="font-headline-lg-mobile text-headline-lg-mobile text-on-primary mt-lg text-center">Entrega Aprobada</h2>
  <p id="result-body" class="font-body-md text-body-md text-on-primary opacity-80 mt-sm text-center">45 kg de PET registrados en el inventario de Fundares.</p>
  <div class="mt-xl bg-primary-container rounded-xl p-lg w-full max-w-xs">
    <p class="font-label-sm text-label-sm text-on-primary-container opacity-80 uppercase tracking-wider mb-xs">Estado final</p>
    <p class="font-title-md text-title-md text-on-primary-container" id="result-status">completado</p>
  </div>
  <button onclick="location.reload()" class="mt-xl h-tap-target-min px-xl bg-surface-container-lowest text-primary rounded-full font-label-md text-label-md active:scale-95 transition-transform">
    Volver al Panel
  </button>
</div>

<script>
  let isEditing = false;
  let rejectExpanded = false;
  let selectedReason = null;

  // Toggle corrección de peso
  function toggleEdit() {
    isEditing = !isEditing;
    const panel = document.getElementById('edit-panel');
    const display = document.getElementById('weight-display');
    const icon = document.getElementById('edit-icon');
    const label = document.getElementById('edit-label');

    if (isEditing) {
      panel.classList.remove('hidden');
      display.classList.add('hidden');
      icon.textContent = 'check';
      label.textContent = 'Guardar';
    } else {
      const val = parseFloat(document.getElementById('corrected-weight').value) || 45;
      document.getElementById('weight-val').textContent = val.toFixed(1).replace('.0','');
      panel.classList.add('hidden');
      display.classList.remove('hidden');
      icon.textContent = 'edit';
      label.textContent = 'Corregir';
    }
  }

  // Seleccionar motivo de rechazo
  function selectReason(btn) {
    document.querySelectorAll('.reason-btn').forEach(b => {
      b.classList.remove('bg-error-container', 'border-error');
      b.classList.add('bg-surface-container-lowest', 'border-outline-variant');
    });
    btn.classList.add('bg-error-container', 'border-error');
    btn.classList.remove('bg-surface-container-lowest');
    selectedReason = btn.dataset.reason;
  }

  // Mostrar/ocultar panel de rechazo
  function handleReject() {
    rejectExpanded = !rejectExpanded;
    const panel = document.getElementById('reject-panel');
    const confirmBtn = document.getElementById('confirm-reject-btn');
    const rejectBtn = document.getElementById('reject-btn');

    if (rejectExpanded) {
      panel.classList.add('open');
      confirmBtn.classList.remove('hidden');
      rejectBtn.textContent = '';
      rejectBtn.innerHTML = '<span class="material-symbols-outlined text-[20px]">expand_less</span> Cancelar';
    } else {
      panel.classList.remove('open');
      confirmBtn.classList.add('hidden');
      rejectBtn.innerHTML = '<span class="material-symbols-outlined text-[20px]">cancel</span> Rechazar';
    }
  }

  // Confirmar rechazo
  function confirmReject() {
    const btn = document.getElementById('confirm-reject-btn');
    btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Procesando...';
    btn.disabled = true;

    setTimeout(() => {
      showResult('rejected');
    }, 1400);
  }

  // Aprobar
  function handleApprove() {
    const btn = document.getElementById('approve-btn');
    btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Procesando...';
    btn.disabled = true;

    setTimeout(() => {
      showResult('approved');
    }, 1400);
  }

  // Mostrar overlay resultado
  function showResult(type) {
    const overlay = document.getElementById('result-overlay');
    const icon = document.getElementById('result-icon');
    const title = document.getElementById('result-title');
    const body = document.getElementById('result-body');
    const status = document.getElementById('result-status');

    const weight = document.getElementById('weight-val').textContent;

    if (type === 'rejected') {
      overlay.classList.remove('bg-primary');
      overlay.classList.add('bg-[#ba1a1a]');
      icon.querySelector('span').textContent = 'block';
      title.textContent = 'Entrega Rechazada';
      body.textContent = selectedReason
        ? `Motivo: ${selectedReason}. El recogedor ha sido notificado.`
        : 'El recogedor ha sido notificado para corregir los datos.';
      status.textContent = 'rechazado';
    } else {
      title.textContent = 'Entrega Aprobada';
      body.textContent = `${weight} kg de PET registrados en el inventario de Fundares.`;
      status.textContent = 'completado';
    }

    overlay.classList.remove('hidden');
    setTimeout(() => {
      icon.classList.remove('scale-0');
      icon.classList.add('scale-100');
    }, 100);
  }
</script>
</body>
</html>
